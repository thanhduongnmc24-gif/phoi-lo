<UserControl x:Class="PhoiLo.UserControls.KcsDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="NHẬP DỮ LIỆU PHÔI GỞI KCS" FontWeight="Bold" FontSize="16"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtFileCount" Text="Số file trong ngày: 0" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" Foreground="#d35400"/>
                <Button Content="🚀 XUẤT EXCEL" Click="BtnExportExcel_Click" Padding="20,5" Background="#2980b9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>
        <DataGrid x:Name="KcsDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                  AlternatingRowBackground="#f2f2f2" PreviewKeyDown="KcsDataGrid_PreviewKeyDown"
                  SelectionUnit="CellOrRowHeader">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="40" IsReadOnly="True"/>
                <DataGridTextColumn Header="Phương thức nạp" Binding="{Binding PhuongThuc}" Width="150"/>
                <DataGridTextColumn Header="Mác phôi" Binding="{Binding MacPhoi}" Width="120"/>
                <DataGridTextColumn Header="Mẻ số" Binding="{Binding MeSo}" Width="100"/>
                <DataGridTextColumn Header="Chiều dài" Binding="{Binding ChieuDai}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>