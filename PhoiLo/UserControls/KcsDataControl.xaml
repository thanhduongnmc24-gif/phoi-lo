<UserControl x:Class="PhoiLo.UserControls.KcsDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo"
             xmlns:models="clr-namespace:PhoiLo.Models">
    <UserControl.Resources>
        <models:BindingProxy x:Key="Proxy" Data="{Binding Source={x:Static local:App.Config}}"/>
    </UserControl.Resources>

    <Grid DataContext="{Binding Source={x:Static local:App.Config}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="NHẬP DỮ LIỆU PHÔI GỞI KCS" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtFileCount" Text="Số file trong ngày: 0" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" Foreground="#d35400"/>
                <Button Content="🗑️ Xóa tất cả" Click="BtnClearAll_Click" Padding="15,5" Background="#e74c3c" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="🚀 XUẤT EXCEL" Click="BtnExportExcel_Click" Padding="20,5" Background="#2980b9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="KcsDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                  AlternatingRowBackground="#f2f2f2" 
                  PreviewKeyDown="KcsDataGrid_PreviewKeyDown"
                  SelectionUnit="CellOrRowHeader"
                  FontSize="{Binding Data.TableFontSize, Source={StaticResource Proxy}}" 
                  FontFamily="{Binding Data.TableFontFamily, Source={StaticResource Proxy}}">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                                           FontSize="{Binding Data.TableFontSize, Source={StaticResource Proxy}}" 
                                           FontFamily="{Binding Data.TableFontFamily, Source={StaticResource Proxy}}"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Background" Value="#2c3e50"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding [STT]}" Width="{Binding Data.KcsCol1Width, Source={StaticResource Proxy}}"/>
                <DataGridTextColumn Header="Phương thức nạp" Binding="{Binding [PhuongThuc]}" Width="{Binding Data.KcsCol2Width, Source={StaticResource Proxy}}"/>
                <DataGridTextColumn Header="Mác phôi" Binding="{Binding [MacPhoi]}" Width="{Binding Data.KcsCol3Width, Source={StaticResource Proxy}}"/>
                <DataGridTextColumn Header="Mẻ số" Binding="{Binding [MeSo]}" Width="{Binding Data.KcsCol4Width, Source={StaticResource Proxy}}"/>
                <DataGridTextColumn Header="Số cây nạp lò" Binding="{Binding [SoCayNap]}" Width="{Binding Data.KcsCol5Width, Source={StaticResource Proxy}}"/>
                <DataGridTextColumn Header="Chiều dài" Binding="{Binding [ChieuDai]}" Width="{Binding Data.KcsCol6Width, Source={StaticResource Proxy}}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>