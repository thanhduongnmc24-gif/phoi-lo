<UserControl x:Class="PhoiLo.UserControls.KcsDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo">
    <Grid DataContext="{Binding Source={x:Static local:App.Config}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="NHẬP DỮ LIỆU PHÔI GỞI KCS" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtFileCount" Text="Số file trong ngày: 0" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" Foreground="#d35400"/>
                <Button Content="🗑️ Xóa tất cả" Click="BtnClearAll_Click" Padding="15,5" Background="#e74c3c" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="🚀 XUẤT EXCEL" Click="BtnExportExcel_Click" Padding="20,5" Background="#2980b9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="KcsDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" 
                  AlternatingRowBackground="#f2f2f2" PreviewKeyDown="KcsDataGrid_PreviewKeyDown"
                  SelectionUnit="CellOrRowHeader"
                  FontSize="{Binding TableFontSize}" FontFamily="{Binding TableFontFamily}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding STT}" Width="{Binding KcsCol1Width}"/>
                <DataGridTextColumn Header="Phương thức nạp" Binding="{Binding PhuongThuc}" Width="{Binding KcsCol2Width}"/>
                <DataGridTextColumn Header="Mác phôi" Binding="{Binding MacPhoi}" Width="{Binding KcsCol3Width}"/>
                <DataGridTextColumn Header="Mẻ số" Binding="{Binding MeSo}" Width="{Binding KcsCol4Width}"/>
                <DataGridTextColumn Header="Số cây nạp lò" Binding="{Binding SoCayNap}" Width="{Binding KcsCol5Width}"/>
                <DataGridTextColumn Header="Chiều dài" Binding="{Binding ChieuDai}" Width="{Binding KcsCol6Width}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>