<UserControl x:Class="PhoiLo.UserControls.KcsDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="NHẬP LIỆU PHÔI GỞI KCS" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="TxtFileCount" Text="Số file đã xuất trong ngày: 0" VerticalAlignment="Center" Margin="0,0,15,0" FontWeight="Bold" Foreground="#d35400"/>
                <Button Content="💾 Xuất ra Excel" Click="BtnExportExcel_Click" Padding="15,5" Background="#2980b9" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="KcsDataGrid" Grid.Row="1" AutoGenerateColumns="True" CanUserAddRows="True" AlternatingRowBackground="#f2f2f2" FontSize="14" FontFamily="Segoe UI">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Background" Value="#2c3e50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </DataGrid.Resources>
        </DataGrid>
    </Grid>
</UserControl>