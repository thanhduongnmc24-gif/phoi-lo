<UserControl x:Class="PhoiLo.UserControls.SheetDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">
            <TextBlock Text="DỮ LIỆU PHÔI RA LÒ (Dòng 11+)" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <Button Content="🔄 Tải lại dữ liệu" Click="BtnReload_Click" HorizontalAlignment="Right" Padding="15,5" Background="#2ecc71" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </DockPanel>

        <DataGrid x:Name="MainDataGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#f9f9f9"/>
    </Grid>
</UserControl>