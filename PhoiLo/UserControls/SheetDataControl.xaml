<UserControl x:Class="PhoiLo.UserControls.SheetDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo">
    
    <Grid DataContext="{Binding Source={x:Static local:App.Config}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <TextBlock Text="DỮ LIỆU PHÔI GỞI PULPIT 1" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🚀 Gởi phôi lên gg sheet" Click="BtnPush_Click" Padding="15,5" Background="#3498db" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="🔄 Tải lại dữ liệu" Click="BtnReload_Click" Padding="15,5" Background="#2ecc71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="MainDataGrid" Grid.Row="1" Grid.Column="0" Margin="0,0,10,0"
                  FontSize="{Binding TableFontSize}" FontFamily="{Binding TableFontFamily}"
                  AutoGenerateColumns="False" IsReadOnly="False" AlternatingRowBackground="#f2f2f2"
                  SelectionUnit="CellOrRowHeader">
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding [STT]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col1Width}"/>
                <DataGridTextColumn Header="Phương thức nạp" Binding="{Binding [Phương thức nạp]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col2Width}"/>
                <DataGridTextColumn Header="Mác phôi" Binding="{Binding [Mác phôi]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col3Width}"/>
                <DataGridTextColumn Header="Mẻ số" Binding="{Binding [Mẻ số]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col4Width}"/>
                <DataGridTextColumn Header="Số cây nạp lò" Binding="{Binding [Số cây nạp lò]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col5Width}"/>
                <DataGridTextColumn Header="Ra sàn nguội" Binding="{Binding [Ra sàn nguội]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col6Width}"/>
                <DataGridTextColumn Header="Hư công nghệ" Binding="{Binding [Hư công nghệ]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col7Width}"/>
                <DataGridTextColumn Header="Hồi lò" Binding="{Binding [Hồi lò]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col8Width}"/>
                <DataGridTextColumn Header="Tổng số thanh" Binding="{Binding [Tổng số thanh khi hết mẻ]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col9Width}"/>
                <DataGridTextColumn Header="Chiều dài" Binding="{Binding [Chiều dài]}" Width="{Binding Source={x:Static local:App.Config}, Path=Col10Width}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Grid.Column="1" Background="#ecf0f1" CornerRadius="5" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="TỔNG HỢP" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#2c3e50" HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Tổng gởi:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="TxtTongPhoi" IsReadOnly="True" Background="#dcdde1" Foreground="#c0392b" FontWeight="Bold" FontSize="18" Padding="5" TextAlignment="Center" Text="0"/>

                    <TextBlock Text="Tổng hồi lò:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtTongHoiLo" IsReadOnly="True" Background="#dcdde1" Foreground="#2980b9" FontWeight="Bold" FontSize="18" Padding="5" TextAlignment="Center" Text="0"/>

                    <TextBlock Text="Ca trước giao:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtPhoiCaTruoc" FontSize="14" Padding="3"/>

                    <TextBlock Text="Ngoài sàn nạp:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtPhoiNgoaiSan" FontSize="14" Padding="3"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>