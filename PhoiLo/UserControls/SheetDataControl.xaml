<UserControl x:Class="PhoiLo.UserControls.SheetDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhoiLo"
             xmlns:models="clr-namespace:PhoiLo.Models">
    <UserControl.Resources>
        <models:BindingProxy x:Key="Proxy" Data="{Binding Source={x:Static local:App.Config}}"/>
    </UserControl.Resources>

    <Grid DataContext="{Binding Source={x:Static local:App.Config}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition x:Name="RightPanelColumn" Width="250"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
            <TextBlock Text="DỮ LIỆU PHÔI GỞI PULPIT 1" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🚀 Gởi phôi lên gg sheet" Click="BtnPush_Click" Padding="15,5" Background="#3498db" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand"/>
                <Button Content="🔄 Tải lại dữ liệu" Click="BtnReload_Click" Padding="15,5" Background="#2ecc71" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="MainDataGrid" Grid.Row="1" Grid.Column="0" Margin="0,0,0,0"
                  AutoGenerateColumns="False" IsReadOnly="False" AlternatingRowBackground="#f2f2f2"
                  SelectionUnit="CellOrRowHeader"
                  PreviewKeyDown="MainDataGrid_PreviewKeyDown"
                  FontSize="{Binding Data.TableFontSize, Source={StaticResource Proxy}}" 
                  FontFamily="{Binding Data.TableFontFamily, Source={StaticResource Proxy}}">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"
                                           FontSize="{Binding Data.TableFontSize, Source={StaticResource Proxy}}" 
                                           FontFamily="{Binding Data.TableFontFamily, Source={StaticResource Proxy}}"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Background" Value="#2c3e50"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="STT" Binding="{Binding [STT]}" />
                <DataGridTextColumn Header="Phương thức nạp" Binding="{Binding [Phương thức nạp]}" />
                <DataGridTextColumn Header="Mác phôi" Binding="{Binding [Mác phôi]}" />
                <DataGridTextColumn Header="Mẻ số" Binding="{Binding [Mẻ số]}" />
                <DataGridTextColumn Header="Số cây nạp lò" Binding="{Binding [Số cây nạp lò]}" />
                <DataGridTextColumn Header="Ra sàn nguội" Binding="{Binding [Ra sàn nguội]}" />
                <DataGridTextColumn Header="Hư công nghệ" Binding="{Binding [Hư công nghệ]}" />
                <DataGridTextColumn Header="Hồi lò" Binding="{Binding [Hồi lò]}" />
                <DataGridTextColumn Header="Tổng số thanh" Binding="{Binding [Tổng số thanh khi hết mẻ]}" />
                <DataGridTextColumn Header="Chiều dài" Binding="{Binding [Chiều dài]}" />
            </DataGrid.Columns>
        </DataGrid>

        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#bdc3c7" ResizeBehavior="PreviousAndNext"/>

        <Border x:Name="SummaryBorder" Grid.Row="1" Grid.Column="2" Background="#ecf0f1" CornerRadius="0,5,5,0" Padding="10" SizeChanged="SummaryBorder_SizeChanged">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="TỔNG HỢP" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#2c3e50" HorizontalAlignment="Center"/>
                    <TextBlock Text="Tổng gởi:" FontWeight="Bold" Margin="0,5,0,2"/>
                    <TextBox x:Name="TxtTongPhoi" IsReadOnly="True" Background="#dcdde1" Foreground="#c0392b" FontWeight="Bold" FontSize="18" Padding="5" TextAlignment="Center" Text="0"/>
                    
                    <TextBlock Text="Phôi nóng:" FontWeight="Bold" Margin="0,10,0,2" Foreground="#e67e22"/>
                    <TextBox x:Name="TxtTongPhoiNong" IsReadOnly="True" Background="#fdf2e9" Foreground="#e67e22" FontWeight="Bold" FontSize="18" Padding="5" TextAlignment="Center" Text="0"/>

                    <TextBlock Text="Tổng hồi lò:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtTongHoiLo" IsReadOnly="True" Background="#dcdde1" Foreground="#2980b9" FontWeight="Bold" FontSize="18" Padding="5" TextAlignment="Center" Text="0"/>

                    <TextBlock Text="📊 Thống kê chiều dài:" FontWeight="Bold" Margin="0,15,0,5"/>
                    <DataGrid x:Name="LengthStatsGrid" AutoGenerateColumns="False" IsReadOnly="True" Height="150" Background="White" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Dài (m)" Binding="{Binding ChieuDai}" Width="*"/>
                            <DataGridTextColumn Header="Số cây" Binding="{Binding SoLuong}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Ca trước giao:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtPhoiCaTruoc" FontSize="14" Padding="3"/>
                    <TextBlock Text="Ngoài sàn nạp:" FontWeight="Bold" Margin="0,10,0,2"/>
                    <TextBox x:Name="TxtPhoiNgoaiSan" FontSize="14" Padding="3"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>