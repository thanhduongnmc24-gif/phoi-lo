<Window x:Class="PhoiLo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhoiLo" 
        Title="Hệ Thống Quản Lý Phôi" Height="650" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Background="#2c3e50" DataContext="{Binding Source={x:Static local:App.Config}}">
            
            <TextBlock Text="DANH MỤC" Foreground="White" FontWeight="Bold" Margin="20,30,20,20" HorizontalAlignment="Center"
                       FontSize="{Binding MenuFontSize}" FontFamily="{Binding MenuFontFamily}"/>
            
            <Button Content="📊 Phôi ra lò(gởi Pulpit 1)" Click="BtnLoadSheet_Click" Height="45" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"
                    FontSize="{Binding MenuFontSize}" FontFamily="{Binding MenuFontFamily}"/>
            
            <Button Content="📦 Phôi gởi KCS" Click="BtnLoadKcs_Click" Height="45" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"
                    FontSize="{Binding MenuFontSize}" FontFamily="{Binding MenuFontFamily}"/>
            
            <Button Content="⚙ Cài đặt" Click="BtnOpenSetting_Click" Height="45" Margin="10,5" Background="Transparent" Foreground="White" BorderThickness="0" Cursor="Hand"
                    FontSize="{Binding MenuFontSize}" FontFamily="{Binding MenuFontFamily}"/>
        </StackPanel>

        <Grid Grid.Column="1" Margin="10">
            <ContentControl x:Name="MainContentArea"/>
        </Grid>
    </Grid>
</Window>