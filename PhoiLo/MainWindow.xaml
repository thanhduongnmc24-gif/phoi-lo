<Window x:Class="PhoiLo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản lý Phôi - Anh Hai" Height="600" Width="1000">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
            <TextBlock Text="Đang kết nối Sheet: " VerticalAlignment="Center" Foreground="Gray"/>
            <TextBlock Text="{Binding SheetId}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,20,0"/>
            <Button Content="⚙ CÀI ĐẶT" Click="BtnOpenSetting_Click" Padding="15,5"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <DataGrid x:Name="SheetDataGrid" AutoGenerateColumns="True" IsReadOnly="True" ItemsSource="{Binding}"/>
            </Grid>
    </Grid>
</Window>