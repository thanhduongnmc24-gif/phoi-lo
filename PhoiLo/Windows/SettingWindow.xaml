<Window x:Class="PhoiLo.Windows.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt hệ thống" Height="750" Width="1000" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/> 
            <ColumnDefinition Width="*"/>   
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,10,0">
                <GroupBox Header="Thông số API &amp; Sheet" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Client ID:"/> <TextBox Text="{Binding ClientId}" Margin="0,5"/>
                        <TextBlock Text="Sheet ID:"/> <TextBox Text="{Binding SheetId}" Margin="0,5"/>
                        <TextBlock Text="Vùng lấy dữ liệu:"/> <TextBox Text="{Binding Range}" Margin="0,5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Độ rộng cột Pulpit 1 (Nhập số)" Padding="10" Margin="0,0,0,10">
                    <UniformGrid Columns="2">
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="STT:"/><TextBox Text="{Binding Col1Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Phương thức:"/><TextBox Text="{Binding Col2Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Mác phôi:"/><TextBox Text="{Binding Col3Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Mẻ số:"/><TextBox Text="{Binding Col4Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Cây nạp:"/><TextBox Text="{Binding Col5Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Ra sàn:"/><TextBox Text="{Binding Col6Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Hư CN:"/><TextBox Text="{Binding Col7Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Hồi lò:"/><TextBox Text="{Binding Col8Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Tổng thanh:"/><TextBox Text="{Binding Col9Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Chiều dài:"/><TextBox Text="{Binding Col10Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Độ rộng cột KCS (Nhập số)" Padding="10" Margin="0,0,0,10">
                    <UniformGrid Columns="2">
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="STT:"/><TextBox Text="{Binding KcsCol1Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Phương thức:"/><TextBox Text="{Binding KcsCol2Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Mác phôi:"/><TextBox Text="{Binding KcsCol3Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Mẻ số:"/><TextBox Text="{Binding KcsCol4Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Cây nạp lò:"/><TextBox Text="{Binding KcsCol5Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                        <StackPanel Margin="5,0,15,5"><TextBlock Text="Chiều dài:"/><TextBox Text="{Binding KcsCol6Width, UpdateSourceTrigger=PropertyChanged}" Padding="2"/></StackPanel>
                    </UniformGrid>
                </GroupBox>

                <GroupBox Header="Giao diện &amp; Font" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Cỡ chữ bảng:"/>
                        <TextBox Text="{Binding TableFontSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" Padding="3"/>
                        <TextBlock Text="Font chữ bảng:"/>
                        <ComboBox SelectedValuePath="Content" SelectedValue="{Binding TableFontFamily}" Margin="0,5">
                            <ComboBoxItem Content="Segoe UI"/><ComboBoxItem Content="Arial"/><ComboBoxItem Content="Times New Roman"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>
                <Button Content="💾 LƯU CẤU HÌNH" Click="BtnSave_Click" Height="40" Background="#27ae60" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </ScrollViewer>

        <GroupBox Grid.Column="1" Header="DANH SÁCH NHÂN SỰ (Kíp A/B/C)" Padding="10">
    <DataGrid ItemsSource="{Binding StaffList}" AutoGenerateColumns="False" CanUserAddRows="True" 
              AlternatingRowBackground="#f2f2f2"
              PreviewKeyDown="StaffGrid_PreviewKeyDown"
              FontSize="{Binding TableFontSize}" FontFamily="{Binding TableFontFamily}">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Kíp" Binding="{Binding Kip}" Width="60"/>
            <DataGridTextColumn Header="Họ Tên" Binding="{Binding HoTen}" Width="*"/>
            <DataGridTextColumn Header="Chức vụ" Binding="{Binding ChucVu}" Width="150"/> 
        </DataGrid.Columns>
    </DataGrid>
</GroupBox>
</Grid>
</Window>